3.	Genome assembly
hifiasm \
--ont \
-t 80 \
--h1 LB0111_good_1.fq.gz \
--h2 LB0111_good_2.fq.gz \
-o LB0111_ont_hic.asm \
ONT_filtered_q8_l1000.fastq.gz

4.	Genome quality assessment
quast.py \
LB0111_ont_hic.p_ctg.fa \
--large \
-o quast

5.	BUSCO analysis
busco \
-i LB0111_ont_hic.p_ctg.fa \
-l aves_odb10 \
-o busco_aves \
-m genome \
-c 80

6.	Hi-C read mapping
bwa-mem2 index LB0111_ont_hic.p_ctg.fa

bwa-mem2 mem \
-t 80 \
LB0111_ont_hic.p_ctg.fa \
LB0111_good_1.fq.gz \
LB0111_good_2.fq.gz | \
samtools sort \
-o hic.sorted.bam

7.	samtools index hic.sorted.bam
